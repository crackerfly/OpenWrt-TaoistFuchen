#!/bin/sh /etc/rc.common

# FakeHTTP - disguise outgoing TCP connections as HTTP to evade DPI.
# Managed by luci-app-taoistfuchen.

USE_PROCD=1
START=99
STOP=10

PROG="/usr/bin/fakehttp"
LOG_FILE="/tmp/fakehttp.log"
BOOTWAIT="/tmp/fakehttp.bootwait"

# Netfilter queue number. MUST differ from FakeSIP (8971) so that both
# services can run at the same time without fighting over the same queue.
QUEUE_NUM=8970

start_service() {
	local enabled interface hostname

	config_load fakehttp
	config_get_bool enabled  main enabled  0
	config_get      interface main interface ''
	config_get      hostname  main hostname  'www.speedtest.net'

	# Disabled in config -> do nothing (this also lets a reload stop it).
	[ "$enabled" = "1" ] || return 0

	if [ -z "$interface" ]; then
		logger -t fakehttp "no network interface configured, not starting"
		return 0
	fi

	[ -n "$hostname" ] || hostname="www.speedtest.net"

	[ -x "$PROG" ] || {
		logger -t fakehttp "binary $PROG missing or not executable"
		return 1
	}

	procd_open_instance fakehttp
	# -i interface, -h hostname, -s silent (no IP logging), -n distinct queue,
	# -w write run log to /tmp (RAM). No -d: procd supervises in foreground.
	procd_set_param command "$PROG" -i "$interface" -h "$hostname" -s -n "$QUEUE_NUM" -w "$LOG_FILE"
	procd_set_param respawn
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	# Reload automatically when the LuCI page saves the config.
	procd_add_reload_trigger "fakehttp"
}

boot() {
	# Optional delayed auto-start at system boot, so a slow WAN (e.g. PPPoE
	# dial-up) has time to come online before the service starts.
	local enabled delay

	config_load fakehttp
	config_get_bool enabled main enabled 0
	[ "$enabled" = "1" ] || return 0

	config_get delay main boot_delay 30
	case "$delay" in ''|*[!0-9]*) delay=30 ;; esac
	[ "$delay" -gt 120 ] && delay=120

	if [ "$delay" -gt 0 ]; then
		# The marker tells the ifup hotplug helper not to start the service
		# early during the wait; the timer below starts it once, cleanly.
		touch "$BOOTWAIT" 2>/dev/null
		( sleep "$delay"; rm -f "$BOOTWAIT" 2>/dev/null; /etc/init.d/fakehttp start ) >/dev/null 2>&1 &
	else
		start
	fi
}
