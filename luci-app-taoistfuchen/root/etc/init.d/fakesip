#!/bin/sh /etc/rc.common

# FakeSIP - disguise outgoing UDP traffic as SIP to evade DPI.
# Managed by luci-app-taoistfuchen.

USE_PROCD=1
START=99
STOP=10

PROG="/usr/bin/fakesip"
LOG_FILE="/tmp/fakesip.log"
BOOTWAIT="/tmp/fakesip.bootwait"

# Netfilter queue number. MUST differ from FakeHTTP (8970) so that both
# services can run at the same time without fighting over the same queue.
QUEUE_NUM=8971

start_service() {
	local enabled interface

	config_load fakesip
	config_get_bool enabled  main enabled  0
	config_get      interface main interface ''

	# Disabled in config -> do nothing (this also lets a reload stop it).
	[ "$enabled" = "1" ] || return 0

	if [ -z "$interface" ]; then
		logger -t fakesip "no network interface configured, not starting"
		return 0
	fi

	[ -x "$PROG" ] || {
		logger -t fakesip "binary $PROG missing or not executable"
		return 1
	}

	procd_open_instance fakesip
	# -i interface, -s silent (no IP logging), -n distinct queue,
	# -w write run log to /tmp (RAM). No -d: procd supervises in foreground.
	procd_set_param command "$PROG" -i "$interface" -s -n "$QUEUE_NUM" -w "$LOG_FILE"
	procd_set_param respawn
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	# Reload automatically when the LuCI page saves the config.
	procd_add_reload_trigger "fakesip"
}

boot() {
	# Optional delayed auto-start at system boot, so a slow WAN (e.g. PPPoE
	# dial-up) has time to come online before the service starts.
	local enabled delay

	config_load fakesip
	config_get_bool enabled main enabled 0
	[ "$enabled" = "1" ] || return 0

	config_get delay main boot_delay 30
	case "$delay" in ''|*[!0-9]*) delay=30 ;; esac
	[ "$delay" -gt 120 ] && delay=120

	if [ "$delay" -gt 0 ]; then
		touch "$BOOTWAIT" 2>/dev/null
		( sleep "$delay"; rm -f "$BOOTWAIT" 2>/dev/null; /etc/init.d/fakesip start ) >/dev/null 2>&1 &
	else
		start
	fi
}
