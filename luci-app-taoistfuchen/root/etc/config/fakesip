config fakesip 'main'
	option enabled '0'
	# Filled with the current default-route device by uci-defaults when known.
	option interface_mode 'selected'
	option direction 'outbound'
	option family 'dual'
	option port_mode 'exclude'
	option ports '53'
	option payload_mode 'auto'
	option sip_uri ''
	option repeat '2'
	option ttl '3'
	option hop_estimation '1'
	option dynamic_ttl_pct '0'
	option log_connections '0'
	option queue_num '8971'
	option fwmark '0x10000'
	option fwmask '0x10000'
